# Runtime environment configuration (MVP placeholders)
# Populate these after deploying the Phase 1 foundation stack and provisioning Bedrock KB resources.

AWS_REGION=us-east-1

# Buckets (from CDK stack outputs)
EVIDENTIA_RAW_BUCKET=
EVIDENTIA_ASSETS_BUCKET=
EVIDENTIA_VECTORS_BUCKET=

# Prefix conventions
EVIDENTIA_RAW_PREFIX=documents-raw
EVIDENTIA_ASSETS_PREFIX=documents-assets

# IAM role / API runtime integration
EVIDENTIA_API_ROLE_ARN=

# Bedrock Knowledge Base (provision in Phase 1 completion)
BEDROCK_KNOWLEDGE_BASE_ID=
BEDROCK_KNOWLEDGE_BASE_DATA_SOURCE_ID=
BEDROCK_KNOWLEDGE_BASE_NAME=
BEDROCK_S3_VECTORS_INDEX_NAME=
BEDROCK_EMBEDDING_MODEL_ARN=

# Claude (Phase 5)
CLAUDE_MODEL_ID=

# API defaults
PRESIGNED_URL_TTL_SECONDS=300
QUERY_TIMEOUT_SECONDS=30
