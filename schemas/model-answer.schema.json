{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/model-answer.schema.json",
  "title": "ModelAnswer",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "answer",
    "citations",
    "used_evidence_ids",
    "limitations"
  ],
  "properties": {
    "answer": {
      "type": "string",
      "minLength": 1
    },
    "citations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "statement",
          "evidence_ids"
        ],
        "properties": {
          "statement": {
            "type": "string",
            "minLength": 1
          },
          "evidence_ids": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^E[1-9][0-9]*$"
            }
          }
        }
      }
    },
    "used_evidence_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^E[1-9][0-9]*$"
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
